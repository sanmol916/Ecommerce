# ─────────────────────────────────────────────────────────────
# Bhama Vision — environment variables
# Copy this file to `.env.local` and fill in your values.
# ─────────────────────────────────────────────────────────────

# Shopify Storefront API (headless backend).
# Leave BOTH blank to run on the bundled sample catalogue (mock provider).
# Fill BOTH to switch the whole storefront to live Shopify data automatically.
#
# How to get these:
#   1. In Shopify admin: Settings → Apps and sales channels → Develop apps
#   2. Create an app → Configure Storefront API scopes
#      (unauthenticated_read_product_listings, _read_product_inventory, etc.)
#   3. Install the app → copy the "Storefront API access token"
#   4. Your domain is the *.myshopify.com one (not the custom domain)

SHOPIFY_STORE_DOMAIN=            # e.g. bhama-vision.myshopify.com
SHOPIFY_STOREFRONT_ACCESS_TOKEN= # e.g. shpat_xxx / public storefront token
